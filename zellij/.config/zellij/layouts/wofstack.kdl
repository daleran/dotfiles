layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    swap_tiled_layout name="stacked" {
        tab {
            pane stacked=true {
                pane
                pane
                pane
            }
        }
    }

    swap_tiled_layout name="vrt2" {
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane size="40%"
            }
        }
    }

    swap_tiled_layout name="vrt2+" {
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane size="40%" stacked=true {
                    pane
                    pane
                }
            }
        }
    }

    swap_tiled_layout name="vrt50" {
        tab {
            pane split_direction="vertical" {
                pane size="50%"
                pane size="50%"
            }
        }
    }

    swap_tiled_layout name="vrt3" {
        tab {
            pane split_direction="vertical" {
                pane size="30%"
                pane size="40%"
                pane size="30%"
            }
        }
    }

    swap_tiled_layout name="hz2" {
        tab {
            pane split_direction="horizontal" {
                pane size="60%"
                pane size="40%"
            }
        }
    }

    swap_tiled_layout name="hz3" {
        tab {
            pane split_direction="horizontal" {
                pane size="30%"
                pane size="30%"
                pane size="40%"
            }
        }
    }

    tab name="wofstack" cwd="~/wofstack" split_direction="vertical" {
        pane size="60%" split_direction="horizontal" {
            pane size="85%" {
                command "yazi"
                args "~/wofstack"
            }
            pane size="15%"
        }
        pane size="40%" stacked=true {
            pane {
                command "claude"
                args "--model" "opusplan"
            }
            pane command="gemini"
            pane
        }
    }

    tab name="w1" cwd="~/w1" split_direction="vertical" {
        pane size="60%" split_direction="horizontal" {
            pane size="85%" {
                command "yazi"
                args "~/w1"
