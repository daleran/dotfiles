layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    swap_tiled_layout name="stacked" {
        tab {
            pane stacked=true {
                pane
                pane
                pane
            }
        }
    }

    swap_tiled_layout name="vrt2" {
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane size="40%"
            }
        }
    }

    swap_tiled_layout name="vrt2+" {
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane size="40%" stacked=true {
                    pane
                    pane
                }
            }
        }
    }

    swap_tiled_layout name="vrt50" {
        tab {
            pane split_direction="vertical" {
                pane size="50%"
                pane size="50%"
            }
        }
    }

    swap_tiled_layout name="vrt3" {
        tab {
            pane split_direction="vertical" {
                pane size="30%"
                pane size="40%"
                pane size="30%"
            }
        }
    }

    swap_tiled_layout name="hz2" {
        tab {
            pane split_direction="horizontal" {
                pane size="60%"
                pane size="40%"
            }
        }
    }

    swap_tiled_layout name="hz3" {
        tab {
            pane split_direction="horizontal" {
                pane size="30%"
                pane size="30%"
                pane size="40%"
            }
        }
    }

    tab name="wofstack" cwd="~/localdev/wofstack" split_direction="vertical" {
        pane size="60%" {
            command "yazi"
            args "~/localdev/wofstack"
        }
        pane size="40%" split_direction="horizontal" {
            pane size="80%" stacked=true {
                pane expanded=true {
                    command "claude"
                    args "--model" "opusplan"
                }
                pane command="gemini"
                pane
            }
            pane size="20%"
        }
    }

    tab name="db" cwd="~/localdev/wofstack" {
        pane {
            name "proddb"
            command "pgcli"
            args "postgres://readonly:gLfPPDFG8X6QrTZYXh*r@10.113.192.234:5432/tmx_production"
        }
    }

    tab name="server" cwd="~/localdev/wofstack" split_direction="vertical" {
        pane {
            name "deployments"
        }
        pane {
            name "ssh admin"
            command "ssh"
            args "admin"
        }
    }
}
