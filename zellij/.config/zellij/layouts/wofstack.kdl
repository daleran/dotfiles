    tab name="db" cwd="~/wofstack" {
        pane {
            name "proddb"
            command "pgcli"
            args "postgres://readonly:gLfPPDFG8X6QrTZYXh*r@10.113.192.234:5432/tmx_production"
        }
    }

    tab name="server" cwd="~/wofstack" split_direction="vertical" {
        pane {
            name "deployments"
        }
        pane {
            name "ssh admin"
            command "ssh"
            args "admin"
        }
    }
}
