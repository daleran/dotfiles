layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    tab name="workspace" cwd="~/localdev/lcconf" split_direction="vertical" {
        pane size="60%" {
            command "yazi"
            args "~/localdev/lcconf"
        }
        pane size="40%"
    }
}
