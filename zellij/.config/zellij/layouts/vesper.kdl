layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }



    tab name="workspace" cwd="${PROJECT_DIR}" split_direction="vertical" {
        pane size="60%" stacked=true {
            pane {
                name "README"
                command "yazi"
                args "~/dotfiles/docs"
            }
            pane
            pane expanded=true {
                name "yazi"
                command "yazi"
                args "~/localdev/vesper"
            }
        }
        pane size="40%" split_direction="horizontal" {
            pane {
                command "claude"
                args "--model" "opusplan" "--chrome"
            }
            pane size="20%" stacked=true {
                pane {
                    command "npm"
                    args "run" "dev"
                }
                pane
            }
        }
    }
}
