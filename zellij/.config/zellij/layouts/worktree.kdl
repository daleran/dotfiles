layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    swap_tiled_layout name="stacked" {
        tab {
            pane stacked=true {
                pane
                pane
                pane
            }
        }
    }

    swap_tiled_layout name="vrt2" {
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane size="40%"
            }
        }
    }

    swap_tiled_layout name="vrt2+" {
        tab {
            pane split_direction="vertical" {
                pane size="60%"
                pane size="40%" stacked=true {
                    pane
                    pane
                }
            }
        }
    }

    swap_tiled_layout name="vrt50" {
        tab {
            pane split_direction="vertical" {
                pane size="50%"
                pane size="50%"
            }
        }
    }

    swap_tiled_layout name="vrt3" {
        tab {
            pane split_direction="vertical" {
                pane size="30%"
                pane size="40%"
                pane size="30%"
            }
        }
    }

    swap_tiled_layout name="hz2" {
        tab {
            pane split_direction="horizontal" {
                pane size="60%"
                pane size="40%"
            }
        }
    }

    swap_tiled_layout name="hz3" {
        tab {
            pane split_direction="horizontal" {
                pane size="30%"
                pane size="30%"
                pane size="40%"
            }
        }
    }

    tab split_direction="vertical" {
        pane size="60%" stacked=true {
            pane {
                name "README"
                command "yazi"
                args "~/dotfiles/docs"
            }
            pane
            pane expanded=true {
                name "yazi"
                command "yazi"
                args "."
            }
        }
        pane size="40%" split_direction="horizontal" {
            pane {
                command "claude"
                args "--model" "opusplan" "--chrome"
            }
            pane size="20%" {
                name "serve"
                command "fish"
                args "-c" "set port (grep -oP 'APP_PORT=\\K[0-9]+' .env 2>/dev/null); composer install --no-interaction; php artisan serve --port=$port"
            }
        }
    }
}
